"], "第16回": ["<span style=\"font-size:13.28px;\">【フレックスアワーズ】</span><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">オンライン授業（課題提示型）</span><span style=\"font-size:13.28px;\">/&nbsp;</span><span style=\"font-size:13.28px;\">《40分》</span></div><div style=\"font-size:13.28px;\">Filming a speech&nbsp;</div>", ""], "第17回": ["<span style=\"font-size:13.28px;\">【コアウィークス⑪】</span><div><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div><span style=\"font-size:13.28px;\">授業中試験</span></div>", ""], "第18回": ["<span style=\"font-size:13.28px;\">【コアウィークス⑫】</span><div><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div>Presentation</div>", ""], "授業計画1": "<span style=\"font-size:13.28px;\">【コアウィークス①～⑫】各Unitを２回の授業で扱い、前半は Warm-up, Key Vocabulary, Introduction of the Interviewee, Interview: Topic 1; 後半は&nbsp;</span><span style=\"font-size:13.28px;\">&nbsp;Interview: Topic 2, 3, Speaking Practice, Reading Passage を学習する。</span><div><span style=\"font-size:13.28px;\">【フレックスアワーズ】各Unitのテーマについて自分のアイデアを表現するスピーチ動画を作成する。（LUNA参照のこと）</span></div>", "授業外学習2": "<span style=\"font-size:13.28px;\">【コアウィークス①～⑫】</span><span style=\"font-size:13.28px;\">《各60分》</span><div><span style=\"font-size:13.28px;\">Unit 前半：⁅予習］&nbsp;</span><span style=\"font-size:13.28px;\">Key Vocabulary　単語を調べてくること</span><span style=\"font-size:13.28px;\">　/ ⁅</span><span style=\"font-size:13.28px;\">復習］ ビデオを何度も視聴して既習表現を習得し、インタビュー内容の理解を深めること</span></div><div><div><span style=\"font-size:13.28px;\">Unit 後半：［</span><span style=\"font-size:13.28px;\">予習］ Reading Passage　問題演習　/ ［</span><span style=\"font-size:13.28px;\">復習］</span><span style=\"font-size:13.28px;\">ビデオを何度も視聴して既習表現を習得し、インタビュー内容の理解を深めること</span><br /><div><span style=\"font-size:13.28px;\">【フレックスアワーズ】</span><span style=\"font-size:13.28px;\">《各10分》</span></div><div><span style=\"font-size:13.28px;\">⁅予習］　LUNAを参照し、課題内容を理解しておくこと</span><span style=\"font-size:13.28px;\">　/ ［</span><span style=\"font-size:13.28px;\">復習］フィードバックの確認</span></div></div></div>"}, "評価": {"教科書/Required texts0": ["著者名\nAuthor", "タイトル\nTitle", "発行所\nPublisher", "出版年\nYear of Publication", "ISBN", "ボタン\nButton"], "教科書/Required texts1": ["Phoebe Amoroso and John Rucynski", "Working in Japan further Explorations", "National Geographic", "2026 年", "9784863124356", ""], "学生による授業評価の方法Course Evaluation by Students0": ["授業アンケート"], "学生による授業評価の方法Course Evaluation by Students1": ["LUNAや教室で行う。"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["授業中試験／In-class examination (03)", "30 %", ""], "成績評価Grading2": ["平常リポート／Individual reports (04)", "50 %", "スタートアップ課題 3%、スピーチ課題6％x5回、振り返りシート1％x17回"], "成績評価Grading3": ["プレゼンテーション・発表／Presentation (07)", "15 %", "プレゼンテーション 10%、振り返り 5%"], "成績評価Grading4": ["授業への参加度（自発性、積極性、主体性、等）／In-class participation,contribution (09)", "5 %", ""], "成績評価Grading5": ["備考　Note この授業は成績評価欄に記載の項目によって、目標（到達目標欄に記載）の到達度を測ります。"], "更新日時/Date of Update0": ["2026年03月09日 14時45分12秒"], "項番No.0": [], "項番No.1": ["2026年度", "春学期／Spring", "木曜３時限／Thursday 3", "春学期／Spring", "Ｇ－２０５"]}, "campas": 0, "name": "【200】英語IIＢ（SW）　１４／English II B(Speaking & Writing) ", "管理部署": 3, "単位数": 1, "担当者": "植野　智子（UENO TOMOKO） ", "履修基準年度": "２年", "履修登録方法": "予備登録", "開講期": 1, "時限1": 23, "評価1": 2, "評価2": 3, "評価3": 4, "評価4": 5, "成績評価備考": "備考　Note\nこの授業は成績評価欄に記載の項目によって、目標（到達目標欄に記載）の到達度を測ります。"}