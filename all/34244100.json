。ヨーロッパ研究科目群：１．国際事情に関する課題の理解力と分析力：世界の諸地域を人文・社会科学の様々な観点から理解し、分析できる。２．問題発見解決能力：主体的に問題を発見し適切な方法に基づいて問題を解決できる。３．異文化理解・多文化共生力：異文化に対する感受性をもち、多様な文化と共生できる。"], "学生による授業評価の方法Course Evaluation by Students2": ["直接またはLUNAにより"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["定期試験／Final Examination (01)", "100 %", ""], "更新日時/Date of Update0": ["2026年02月19日 18時09分56秒"], "項番No.0": [], "項番No.1": ["2026年度", "春学期／Spring", "火曜２時限／Tuesday 2", "春学期／Spring", "Ｇ－ＩＳ２０６"]}, "campas": 0, "name": "【330】ＥＵの自動車産業／The Automobile Industry in the European Union - Issues, Policies and Actors [JP]", "管理部署": 10, "単位数": 2, "担当者": "ブングシェ　Ｈ．Ｒ．（BUNGSCHE HOLGER ROBERT） ", "履修基準年度": "２年", "履修登録方法": "本登録", "開講期": 1, "時限1": 8, "時限1_term": 0, "評価1": 0}