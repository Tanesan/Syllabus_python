13.28px;\"><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">テーマ：</span><span style=\"font-size:13.28px;\">エスニシティ（２）</span></div></div>", "<span style=\"font-size:13.28px;\">授業内容に即した課題に回答する</span><div>授業内テスト③の準備</div>"], "第15回": ["<span style=\"font-size:13.28px;\">【コアウィークス</span><span lang=\"EN-US\" style=\"font-size:10pt;line-height:14.266666px;color:rgb(36,36,36);border:1pt windowtext;padding:0mm;\">⑫</span><span style=\"font-size:13.28px;\">】</span><div><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div><span style=\"font-size:13.28px;\">映像視聴レポートに対するフィードバック＋授業内テスト③の実施</span></div>", ""], "授業計画1": "授業全体を通じてドキュメンタリー映像を視聴する機会を設けるが、とくにフレックスアワーズにおいて動画や映画視聴を課す。映画館での映画視聴の場合は映画鑑賞料、ネット配信の場合はサブスク料が必要となる。", "授業外学習2": "授業内容に基づくフィードバックコメントの提出を求める。履修者は、授業で取り上げられるトピックに関連したメディア報道、ドキュメンタリー番組などに関心を持ち、授業内でのディスカッションに生かすこと。"}, "評価": {"教科書/Required texts0": ["とくになし"], "参考文献・資料/Reference books0": ["授業時に用いるスライドは，原則として紙媒体で授業開始時に配布する。LUNAでも事後配布を行うが、ダウンロードは不可とする。その他授業内容に関連する文献／資料は授業内で指示する。"], "課題等へのフィードバック方法Methods for Providing Feedback on Assignments0": ["フィードバックコメントの一部は授業内で紹介する。"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["授業中試験／In-class examination (03)", "60 %", ""], "成績評価Grading2": ["平常リポート／Individual reports (04)", "20 %", "フレックスアワーズの課題"], "成績評価Grading3": ["授業外学修課題／Assignment, homework required outside class (06)", "20 %", "フィードバックコメント・次回授業関連課題の提出"], "成績評価Grading4": ["備考　Note 授業中試験とは、コアウィークスの授業中に3度に分けて実施する授業内テストを指す。毎回の授業に出席し、内容を十分に理解していることが必要である。"], "更新日時/Date of Update0": ["2026年03月30日 19時15分24秒"], "項番No.0": [], "項番No.1": ["2026年度", "春学期／Spring", "火曜３時限／Tuesday 3", "春学期／Spring", "Ｈ－２０１"]}, "campas": 0, "name": "【200】文化人類学Ａ／Cultural Anthropology A", "管理部署": 2, "単位数": 2, "担当者": "中谷　文美（NAKATANI AYAMI） ", "履修基準年度": "１年", "履修登録方法": "本登録", "開講期": 1, "時限1": 9, "時限1_term": 0, "評価1": 2, "評価2": 3, "評価3": 7, "成績評価備考": "備考　Note\n授業中試験とは、コアウィークスの授業中に3度に分けて実施する授業内テストを指す。毎回の授業に出席し、内容を十分に理解していることが必要である。"}