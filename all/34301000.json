"}, "評価": {"教科書/Required texts0": ["LUNA上で抜粋部分を配布予定。"], "参考書/Reference books0": ["著者名\nAuthor", "タイトル\nTitle", "発行所\nPublisher", "出版年\nYear of Publication", "ISBN", "ボタン\nButton"], "参考書/Reference books1": ["コーラル・アン・ハウエルズ他", "『ケンブリッジ版 カナダ文学史』", "彩流社", "2009 年", "", ""], "学生による授業評価の方法Course Evaluation by Students0": ["授業評価アンケート"], "学生による授業評価の方法Course Evaluation by Students1": ["各授業科目は、各学部・研究科の定めるディプロマ・ポリシー（DP）・カリキュラム・ポリシー（CP）に基づき、カリキュラム上に配置されています。DP・CPを意識して本授業科目の学修を進めることで、各学部・研究科の期待する以下の能力が養成されます。北米研究科目群：１．国際事情に関する課題の理解力と分析力：世界の諸地域を人文・社会科学の様々な観点から理解し、分析できる。２．問題発見解決能力：主体的に問題を発見し適切な方法に基づいて問題を解決できる。３．異文化理解・多文化共生力：異文化に対する感受性をもち、多様な文化と共生できる。"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["授業中試験／In-class examination (03)", "30 %", "毎週の授業後に提出するコメントシート"], "成績評価Grading2": ["平常リポート／Individual reports (04)", "70 %", "最終レポート（Final essay）"], "更新日時/Date of Update0": ["2026年02月27日 16時09分28秒"], "項番No.0": [], "項番No.1": ["2026年度", "春学期／Spring", "金曜４時限／Friday 4", "春学期／Spring", "Ｇ－２０２"]}, "campas": 0, "name": "【340】北米文化論／Cultures in North America [JP]", "管理部署": 10, "単位数": 2, "担当者": "安保　夏絵（AMBO NATSUE） ", "履修基準年度": "２年", "履修登録方法": "本登録", "開講期": 1, "時限1": 31, "評価1": 2, "評価2": 3}