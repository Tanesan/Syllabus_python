, "評価": {"参考文献・資料/Reference books0": ["谷田貝豊彦『例題で学ぶ 光学入門』（森北出版、2010）\n谷田貝豊彦『光学』（新倉書店、2017）\n青木貞雄『光学入門』（共立出版、2002）\n堀内敏行『光技術入門』（東京電機大学出版局、2005）\n竹内淳『高校数学でわかる光とレンズ』（講談社、2016）\n大坪順次『光入門』（コロナ社、2002）\nヘクト『光学I』『光学II』『光学III』（丸善、2002）\n砂川重信『電磁気学（物理テキストシリーズ４）』（岩波書店、1987）"], "学生による授業評価の方法Course Evaluation by Students0": ["授業中実施"], "学生による授業評価の方法Course Evaluation by Students1": ["各授業科目は、各学部・研究科の定めるディプロマ・ポリシー（DP）・カリキュラム・ポリシー（CP）に基づき、カリキュラム上に配置されています。DP・CPを意識して本授業科目の学修を進めることで、各学部・研究科の期待する能力が養成されます。各学部・研究科のDP、CPや教育課程表（授業科目一覧等）は、下記リンクこちらに掲載していますので学修計画の参考にしてください。https://kwic.kwansei.ac.jp/cabinet/reference?typeCd=0&amp;cabinetId=557&amp;directLink=1※kwicへのリンクとなります（在学生のみ閲覧可）"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["定期試験／Final Examination (01)", "70 %", ""], "成績評価Grading2": ["平常リポート／Individual reports (04)", "30 %", "授業中に小課題を出しLUNAで解答する"], "更新日時/Date of Update0": ["2026年04月01日 15時51分32秒"], "項番No.0": [], "項番No.1": ["2026年度", "春学期／Spring", "金曜２時限／Friday 2", "春学期／Spring", "ＩＶ－４０２"]}, "campas": 1, "name": "【200】デモンストレーション物理学II／Physics Demonstration II", "管理部署": 12, "単位数": 2, "担当者": "松浦　周二（MATSUURA SHUJI） ", "履修基準年度": "２年", "履修登録方法": "本登録", "開講期": 1, "時限1": 29, "時限1_term": 0, "評価1": 0, "評価2": 3}