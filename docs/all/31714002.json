ndent:-132.266663px;\"><span style=\"font-family:游明朝, serif;\">テスト予備日て</span></div></div></div></div>", "<span style=\"font-size:13.28px;\">授業動画を視聴し、取り組みや技術の振り返りを行う</span>"], "第15回": ["【フレックスアワーズ】オンライン授業（課題提示型）／《90分》<div>これまでの授業動画を視聴し、授業ノートを作成する</div>", ""], "授業外学習2": "本授業は実技を伴うため、学習に備えてストレッチを実施し、体調を整える。"}, "評価": {"学位授与の方針との関連Relationship to Diploma Policy0": ["各授業科目は、各学部・研究科の定めるディプロマ・ポリシー（DP）・カリキュラム・ポリシー（CP）に基づき、カリキュラム上に配置されています。\nDP・CPを意識して本授業科目の学修を進めることで、各学部・研究科の期待する能力が養成されます。\n各学部・研究科のDP、CPや教育課程表（授業科目一覧等）は、下記リンクこちらに掲載していますので学修計画の参考にしてください。\nhttps://kwic.kwansei.ac.jp/cabinet/reference?typeCd=0&amp;cabinetId=557&amp;directLink=1\n※kwicへのリンクとなります（在学生のみ閲覧可）"], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["授業中試験／In-class examination (03)", "60 %", "技能試験"], "成績評価Grading2": ["授業への参加度（自発性、積極性、主体性、等）／In-class participation,contribution (09)", "10 %", ""], "成績評価Grading3": ["その他／Others (99)", "30 %", "授業ノートの採点"], "成績評価Grading4": ["備考　Note 全回出席を原則とする。単位習得には3分の2以上の出席が必要である。"], "備考Note0": ["動きやすい服装（フードの付いていないもの）を用意する。\n腕時計や貴金属類は外し、長髪のものは運動の妨げにならないようにする。"], "備考Note1": ["2026年01月09日 11時48分33秒"], "項番No.0": [], "項番No.1": ["2026年度", "秋学期／Fall", "月曜３時限／Monday 3", "秋学期／Fall", "小フロア"]}, "campas": 0, "name": "【250】体操　２／Gymnastics", "管理部署": 8, "単位数": 1, "担当者": "西田　昂平（NISHIDA KOHEI） ", "履修基準年度": "１年", "履修登録方法": "申込制", "開講期": 2, "時限1": 2, "時限1_term": 1, "評価1": 2, "評価2": 5, "評価3": 6, "成績評価備考": "備考　Note\n全回出席を原則とする。単位習得には3分の2以上の出席が必要である。"}