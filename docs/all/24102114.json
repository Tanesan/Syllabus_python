e=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">オンライン授業（課題提示型）</span><span style=\"font-size:13.28px;\">／</span><span style=\"font-size:13.28px;\">《30分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">Unit 11 Video Journal&nbsp;</span></div>", ""], "第17回": ["<span style=\"font-size:13.28px;\">【</span><span style=\"font-size:13.28px;\">コアウィークス⑪】</span><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">Unit 12 Celebrations&nbsp;</span><span style=\"font-size:13.28px;\">前半</span></div>", ""], "第18回": ["<span style=\"font-size:13.28px;\">【</span><span style=\"font-size:13.28px;\">コアウィークス<span style=\"font-size:13.28px;\">⑫</span>】</span><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《90分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">Unit&nbsp;</span><span style=\"font-size:13.28px;\">12 Celebrations 後半</span></div>", ""], "第19回": ["<span style=\"font-size:13.28px;\">【フレックスアワーズ】</span><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">オンライン授業（課題提示型）</span><span style=\"font-size:13.28px;\">／</span><span style=\"font-size:13.28px;\">《30分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">Unit 12 Video Journal&nbsp;</span></div>", ""], "第20回": ["<span style=\"font-size:13.28px;\">【授業・試験期間】1週目</span><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">対面授業／</span><span style=\"font-size:13.28px;\">《60分》</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">1月7日　</span><span style=\"font-size:13.28px;\">授業中試験を</span><span style=\"font-size:13.28px;\">通常教室で</span><span style=\"font-size:13.28px;\">実施</span></div>", ""], "授業計画1": "<span style=\"font-size:13.28px;\">【コアウィークス①～⑫】各Unit を2回の授業で扱い、前半はVocabulary, Grammar, Listening, Language Expansion;&nbsp;</span><span style=\"font-size:13.28px;\">後半はReadingを学習する。</span><div><span style=\"font-size:13.28px;\">【フレックスアワーズ】</span><span style=\"font-size:13.28px;\">各Unit</span><span style=\"font-size:13.28px;\">&nbsp;のテーマに関する内容の</span><span style=\"font-size:13.28px;\">TED Talksなどのスピーチを視聴する。</span></div>", "授業外学習2": "<div><span style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">【</span>コアウィークス①～⑫】</span><span style=\"font-size:13.28px;\">《各60分》</span><div style=\"font-size:13.28px;\">Unit 前半：［予習］Vocabulary,&nbsp;<span style=\"font-size:13.28px;\">Language Expansion の単語を調べておくこと /&nbsp;</span><span style=\"font-size:13.28px;\">［</span><span style=\"font-size:13.28px;\">復習］単語や文法、リスニングを復習すること。</span></div><div style=\"font-size:13.28px;\"><span style=\"font-size:13.28px;\">Unit 後半：</span><span style=\"font-size:13.28px;\">［予習］ワークシートの単語を調べておくこと</span><span style=\"font-size:13.28px;\">/&nbsp;</span><span style=\"font-size:13.28px;\">［</span><span style=\"font-size:13.28px;\">復習］単語やReadingの復習、ワークシートを完成させること。</span></div><div style=\"font-size:13.28px;\"><div><span style=\"font-size:13.28px;\">【フレックスアワーズ】</span><span style=\"font-size:13.28px;\">《各10分》</span></div><div><span style=\"font-size:13.28px;\">［</span><span style=\"font-size:13.28px;\">予習］LUNAを参照し、課題内容を理解しておくこと</span><span style=\"font-size:13.28px;\">&nbsp;/&nbsp;</span><span style=\"font-size:13.28px;\">［</span><span style=\"font-size:13.28px;\">復習］フィードバックを確認すること。</span></div></div></span></div>"}, "評価": {"教科書/Required texts0": ["著者名\nAuthor", "タイトル\nTitle", "発行所\nPublisher", "出版年\nYear of Publication", "ISBN", "ボタン\nButton"], "教科書/Required texts1": ["Kristin L. Johannsen and Rebecca Tarver Chase", "World English, Third Edition", "National Geographic", "2020 年", "9798214085272", ""], "成績評価Grading0": ["種別　Type備考　Note", "割合　Percentage", "評価基準等　Grading Criteria etc."], "成績評価Grading1": ["授業中試験／In-class examinati